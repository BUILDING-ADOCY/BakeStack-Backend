generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum LocationType {
  CAFE
  BAKERY
  KITCHEN
  COMMISSARY
  WAREHOUSE
  CLOUD_KITCHEN
}

enum BusinessType {
  BAKERY
  CAFE
  BAKERY_CAFE
  CLOUD_KITCHEN
  HOME_BAKER
  PATISSERIE
  BREAD_BAKERY
  CENTRAL_KITCHEN
  OTHER
}

enum BusinessStage {
  IDEA_STAGE
  PRE_LAUNCH
  NEWLY_OPENED
  RUNNING
  SCALING
  MULTI_LOCATION
}

enum ServiceMode {
  DINE_IN
  TAKEAWAY
  DELIVERY
  PRE_ORDER
  WHOLESALE
  CATERING
  CLOUD_KITCHEN
}

enum SetupStepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ComplianceStatus {
  NOT_PROVIDED
  PENDING
  VERIFIED
  REJECTED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductImportStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum InventoryItemType {
  RAW_MATERIAL
  PACKAGING
  WORK_IN_PROGRESS
  FINISHED_GOOD
}

enum InventoryMovementType {
  OPENING_STOCK
  PURCHASE_RECEIPT
  PRODUCTION_CONSUMPTION
  PRODUCTION_OUTPUT
  WASTAGE
  STOCK_ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  COUNT_CORRECTION
}

enum InventoryImportStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum GoodsReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum RecipeStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductionPlanStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionBatchStatus {
  PLANNED
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  QC_HOLD
}

enum WasteReasonCode {
  EXPIRED
  DAMAGED
  OVERPRODUCTION
  QUALITY_FAILURE
  RETURNED
  WRONG_BATCH
  STAFF_ERROR
  OTHER
}

enum QCStatus {
  PENDING
  PASSED
  FAILED
  HOLD
  RELEASED
}

enum DailyCloseStatus {
  OPEN
  DRAFT
  CLOSED
  REOPENED
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  DUPLICATE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SupplierInvoiceStatus {
  DRAFT
  RECEIVED
  APPROVED
  PAID
  VOID
}

enum ProcurementSourceType {
  MANUAL
  LOW_STOCK
  PRODUCTION_PLAN
  FORECAST
  RECURRING
}

enum ProcurementRequestStatus {
  DRAFT
  PENDING_APPROVAL
  SUPPLIER_REQUEST_CREATED
  SUPPLIER_MESSAGE_SENT
  SUPPLIER_RESPONDED
  QUOTATION_RECEIVED
  CONFIRMED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum ProcurementRequestItemStatus {
  PENDING
  ASSIGNED
  UNASSIGNED
  QUOTED
  ACCEPTED
  REJECTED
  RECEIVED
}

enum SupplierRequestStatus {
  DRAFT
  READY_TO_SEND
  SENT
  DELIVERED
  SEEN
  AWAITING_REPLY
  SUPPLIER_REPLIED
  QUOTATION_RECEIVED
  NEGOTIATION
  ACCEPTED
  REJECTED
  PO_CREATED
  DELIVERY_PENDING
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
  ESCALATED
}

enum SupplierMessageSenderType {
  BAKERY_USER
  SUPPLIER
  SYSTEM
  AI_ASSISTANT
}

enum SupplierMessageChannel {
  EMAIL
  SMS
  WHATSAPP
  PORTAL
  IN_APP
  PUSH
}

enum SupplierMessageStatus {
  DRAFT
  READY_TO_SEND
  SENDING
  SENT
  DELIVERED
  FAILED
  FAILED_PROVIDER_NOT_CONFIGURED
  FAILED_TARGET_NOT_FOUND
  READ
  RECEIVED
}

enum SupplierQuotationStatus {
  DRAFT
  RECEIVED
  NEGOTIATION
  ACCEPTED
  REJECTED
  EXPIRED
  PO_CREATED
}

model Tenant {
  id                      String                          @id @default(uuid()) @db.Uuid
  name                    String
  legalName               String?
  securityOrganizationId  String?                         @unique
  timezone                String
  currency                String
  status                  TenantStatus                    @default(ACTIVE)
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  auditLogs               AuditLog[]
  businessProfile         BusinessProfile?
  complianceProfiles      ComplianceProfile[]
  dailyCloses             DailyClose[]
  goodsReceiptLines       GoodsReceiptLine[]
  goodsReceipts           GoodsReceipt[]
  idempotencyKeys         IdempotencyKey[]
  inventoryBalances       InventoryBalance[]
  inventoryImports        InventoryImport[]
  inventoryItems          InventoryItem[]
  inventoryLots           InventoryLot[]
  inventoryMovements      InventoryMovement[]
  locations               Location[]
  locationInventoryItems  LocationInventoryItemSetting[]
  locationProfiles        LocationProfile[]
  locationProductVariants LocationProductVariantSetting[]
  locationSupplierItems   LocationSupplierItemSetting[]
  onboardingProgresses    OnboardingProgress[]
  openingHours            OpeningHour[]
  productCategories       ProductCategory[]
  productImports          ProductImport[]
  productVariants         ProductVariant[]
  products                Product[]
  procurementRequestItems ProcurementRequestItem[]
  procurementRequests     ProcurementRequest[]
  productionBatchItems    ProductionBatchItem[]
  productionBatches       ProductionBatch[]
  productionConsumpt      ProductionConsumption[]
  productionOutputs       ProductionOutput[]
  productionPlans         ProductionPlan[]
  purchaseOrderLines      PurchaseOrderLine[]
  purchaseOrders          PurchaseOrder[]
  qcChecks                QCCheck[]
  recipeComponents        RecipeComponent[]
  recipes                 Recipe[]
  roles                   Role[]
  salesEntries            SalesEntry[]
  supplierInvoices        SupplierInvoice[]
  supplierItems           SupplierItem[]
  supplierMessageThreads  SupplierMessageThread[]
  supplierMessages        SupplierMessage[]
  supplierQuotations      SupplierQuotation[]
  supplierRequestItems    SupplierRequestItem[]
  supplierRequests        SupplierRequest[]
  suppliers               Supplier[]
  userRoleAssignments     UserRoleAssignment[]
  users                   User[]
  wasteEvents             WasteEvent[]
  webhookInbox            WebhookInbox[]
}

model Location {
  id                     String                          @id @default(uuid()) @db.Uuid
  tenantId               String                          @db.Uuid
  name                   String
  type                   LocationType
  address                Json?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  postalCode             String?
  country                String                          @default("India")
  countryCode            String                          @default("IN")
  currencyCode           String                          @default("INR")
  latitude               Decimal?                        @db.Decimal(10, 6)
  longitude              Decimal?                        @db.Decimal(10, 6)
  phone                  String?
  email                  String?
  timezone               String                          @default("Asia/Kolkata")
  isPrimary              Boolean                         @default(false)
  isActive               Boolean                         @default(true)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  tenant                 Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  complianceProfiles     ComplianceProfile[]
  dailyCloses            DailyClose[]
  goodsReceipts          GoodsReceipt[]
  inventoryBalances      InventoryBalance[]
  inventoryImports       InventoryImport[]
  inventoryItemSettings  LocationInventoryItemSetting[]
  inventoryMovements     InventoryMovement[]
  locationProfile        LocationProfile?
  openingHours           OpeningHour[]
  productionPlans        ProductionPlan[]
  productionBatches      ProductionBatch[]
  procurementRequests    ProcurementRequest[]
  productVariantSettings LocationProductVariantSetting[]
  purchaseOrders         PurchaseOrder[]
  qcChecks               QCCheck[]
  salesEntries           SalesEntry[]
  userAssignments        UserRoleAssignment[]
  supplierItemSettings   LocationSupplierItemSetting[]
  wasteEvents            WasteEvent[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isPrimary])
  @@index([tenantId, type])
  @@index([tenantId, countryCode])
}

model User {
  id                         String               @id @default(uuid()) @db.Uuid
  tenantId                   String               @db.Uuid
  securityUserId             String?              @unique
  email                      String
  displayName                String
  phone                      String?
  status                     UserStatus           @default(INVITED)
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  tenant                     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs                  AuditLog[]           @relation("AuditActor")
  dailyClosesClosed          DailyClose[]         @relation("DailyCloseClosedBy")
  goodsReceiptsReceived      GoodsReceipt[]       @relation("GoodsReceiptReceivedBy")
  inventoryImports           InventoryImport[]    @relation("InventoryImportUploadedBy")
  inventoryMovements         InventoryMovement[]  @relation("InventoryMovementCreatedBy")
  onboardingProgresses       OnboardingProgress[]
  productImports             ProductImport[]      @relation("ProductImportUploadedBy")
  procurementRequestsCreated ProcurementRequest[] @relation("ProcurementRequestCreatedBy")
  purchaseOrdersCreated      PurchaseOrder[]      @relation("PurchaseOrderCreatedBy")
  productionPlansCreated     ProductionPlan[]     @relation("ProductionPlanCreatedBy")
  productionPlansApproved    ProductionPlan[]     @relation("ProductionPlanApprovedBy")
  productionBatchesCreated   ProductionBatch[]    @relation("ProductionBatchCreatedBy")
  productionBatchesApproved  ProductionBatch[]    @relation("ProductionBatchApprovedBy")
  qcChecks                   QCCheck[]            @relation("QCCheckedBy")
  recipeCreated              Recipe[]             @relation("RecipeCreatedBy")
  roleAssignments            UserRoleAssignment[]
  salesEntriesCreated        SalesEntry[]         @relation("SalesEntryCreatedBy")
  wasteEventsRecorded        WasteEvent[]         @relation("WasteRecordedBy")
  wasteEventsVoided          WasteEvent[]         @relation("WasteVoidedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
}

model Role {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @db.Uuid
  name            String
  description     String?
  policyJson      Json
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleAssignments UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model UserRoleAssignment {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  userId        String    @db.Uuid
  roleId        String    @db.Uuid
  locationId    String?   @db.Uuid
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, locationId])
}

model BusinessProfile {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @unique @db.Uuid
  businessName    String
  legalName       String?
  brandName       String?
  businessType    BusinessType
  businessStage   BusinessStage?
  ownerName       String?
  ownerPhone      String?
  ownerEmail      String?
  websiteUrl      String?
  instagramUrl    String?
  description     String?
  logoUrl         String?
  timezone        String         @default("Asia/Kolkata")
  currency        String         @default("INR")
  defaultLanguage String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, businessType])
}

model LocationProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @db.Uuid
  locationId            String   @unique @db.Uuid
  storeDisplayName      String?
  storeManagerName      String?
  storeManagerPhone     String?
  seatingCapacity       Int?
  tableCount            Int?
  kitchenType           String?
  hasInHouseKitchen     Boolean? @default(false)
  hasCentralKitchen     Boolean? @default(false)
  hasDelivery           Boolean? @default(false)
  hasTakeaway           Boolean? @default(false)
  hasDineIn             Boolean? @default(false)
  hasWholesale          Boolean? @default(false)
  hasCatering           Boolean? @default(false)
  serviceModes          Json?
  averageDailyOrders    Int?
  averageDailyRevenue   Decimal? @db.Decimal(14, 2)
  monthlyRent           Decimal? @db.Decimal(14, 2)
  currencyCode          String?
  staffCount            Int?
  productionStartTime   String?
  productionEndTime     String?
  peakHoursJson         Json?
  cuisineOrProductFocus String?
  signatureProductsJson Json?
  targetCustomersJson   Json?
  pricePositioning      String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  location              Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId])
  @@index([tenantId])
}

model OpeningHour {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  locationId String    @db.Uuid
  dayOfWeek  DayOfWeek
  openTime   String?
  closeTime  String?
  isClosed   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId, dayOfWeek])
  @@index([tenantId])
  @@index([tenantId, locationId])
}

model ComplianceProfile {
  id                         String           @id @default(uuid()) @db.Uuid
  tenantId                   String           @db.Uuid
  locationId                 String?          @db.Uuid
  countryCode                String           @default("IN")
  gstin                      String?
  fssaiLicenseNumber         String?
  fssaiExpiryDate            DateTime?
  panNumber                  String?
  businessRegistrationNumber String?
  taxRegistrationNumber      String?
  foodSafetyLicenseNumber    String?
  metadataJson               Json?
  status                     ComplianceStatus @default(NOT_PROVIDED)
  notes                      String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  location                   Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  tenant                     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([tenantId, status])
  @@index([tenantId, countryCode])
}

model OnboardingProgress {
  id                    String          @id @default(uuid()) @db.Uuid
  tenantId              String          @db.Uuid
  userId                String          @db.Uuid
  businessProfileStatus SetupStepStatus @default(NOT_STARTED)
  locationSetupStatus   SetupStepStatus @default(NOT_STARTED)
  cafeProfileStatus     SetupStepStatus @default(NOT_STARTED)
  complianceStatus      SetupStepStatus @default(NOT_STARTED)
  productSetupStatus    SetupStepStatus @default(NOT_STARTED)
  inventorySetupStatus  SetupStepStatus @default(NOT_STARTED)
  recipeSetupStatus     SetupStepStatus @default(NOT_STARTED)
  supplierSetupStatus   SetupStepStatus @default(NOT_STARTED)
  productionSetupStatus SetupStepStatus @default(NOT_STARTED)
  isCompleted           Boolean         @default(false)
  completedAt           DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([tenantId, isCompleted])
}

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  name        String
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  categoryId     String?          @db.Uuid
  name           String
  description    String?
  status         ProductStatus    @default(ACTIVE)
  allergenJson   Json?
  shelfLifeHours Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  category       ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants       ProductVariant[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

model ProductVariant {
  id                   String                          @id @default(uuid()) @db.Uuid
  tenantId             String                          @db.Uuid
  productId            String                          @db.Uuid
  inventoryItemId      String?                         @unique @db.Uuid
  sku                  String
  name                 String
  unit                 String
  defaultSellingPrice  Decimal?                        @db.Decimal(14, 2)
  currencyCode         String?
  status               ProductStatus                   @default(ACTIVE)
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt
  deletedAt            DateTime?
  inventoryItem        InventoryItem?                  @relation("FinishedGoodInventoryItem", fields: [inventoryItemId], references: [id], onDelete: SetNull)
  product              Product                         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant               Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionBatchItems ProductionBatchItem[]
  recipes              Recipe[]
  salesEntries         SalesEntry[]
  locationSettings     LocationProductVariantSetting[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

model LocationProductVariantSetting {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @db.Uuid
  locationId       String         @db.Uuid
  productVariantId String         @db.Uuid
  sellingPrice     Decimal?       @db.Decimal(14, 2)
  currencyCode     String
  isAvailable      Boolean?
  metadataJson     Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  location         Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId, productVariantId])
  @@index([tenantId, locationId])
  @@index([tenantId, productVariantId])
}

model ProductImport {
  id                     String              @id @default(uuid()) @db.Uuid
  tenantId               String              @db.Uuid
  uploadedById           String?             @db.Uuid
  fileName               String
  contentType            String?
  fileSizeBytes          Int
  sourceFileText         String?
  status                 ProductImportStatus @default(PROCESSING)
  totalRows              Int                 @default(0)
  processedRows          Int                 @default(0)
  createdCategoriesCount Int                 @default(0)
  createdProductsCount   Int                 @default(0)
  updatedProductsCount   Int                 @default(0)
  createdVariantsCount   Int                 @default(0)
  updatedVariantsCount   Int                 @default(0)
  errorCount             Int                 @default(0)
  summaryJson            Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy             User?               @relation("ProductImportUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model InventoryItem {
  id                      String                         @id @default(uuid()) @db.Uuid
  tenantId                String                         @db.Uuid
  name                    String
  type                    InventoryItemType
  defaultUom              String
  unitCost                Decimal                        @db.Decimal(14, 4)
  currencyCode            String?
  shelfLifeDays           Int?
  reorderLevel            Decimal?                       @db.Decimal(14, 4)
  isPerishable            Boolean                        @default(false)
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  deletedAt               DateTime?
  tenant                  Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  finishedGoodVariant     ProductVariant?                @relation("FinishedGoodInventoryItem")
  balances                InventoryBalance[]
  goodsReceiptLines       GoodsReceiptLine[]
  lots                    InventoryLot[]
  movements               InventoryMovement[]
  locationSettings        LocationInventoryItemSetting[]
  procurementRequestItems ProcurementRequestItem[]
  purchaseOrderLines      PurchaseOrderLine[]
  productionConsumpt      ProductionConsumption[]
  productionOutputs       ProductionOutput[]
  recipeComponents        RecipeComponent[]
  supplierRequestItems    SupplierRequestItem[]
  supplierItems           SupplierItem[]
  wasteEvents             WasteEvent[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, deletedAt])
}

model LocationInventoryItemSetting {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  locationId      String        @db.Uuid
  inventoryItemId String        @db.Uuid
  unitCost        Decimal?      @db.Decimal(14, 4)
  reorderLevel    Decimal?      @db.Decimal(14, 4)
  currencyCode    String
  isStocked       Boolean?
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  location        Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId, inventoryItemId])
  @@index([tenantId, locationId])
  @@index([tenantId, inventoryItemId])
}

model InventoryLot {
  id                 String                  @id @default(uuid()) @db.Uuid
  tenantId           String                  @db.Uuid
  inventoryItemId    String                  @db.Uuid
  supplierId         String?                 @db.Uuid
  supplierBatchNo    String?
  receivedAt         DateTime?
  expiryAt           DateTime?
  createdAt          DateTime                @default(now())
  inventoryItem      InventoryItem           @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplier           Supplier?               @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balances           InventoryBalance[]
  goodsReceiptLines  GoodsReceiptLine[]
  movements          InventoryMovement[]
  productionConsumpt ProductionConsumption[]
  productionOutputs  ProductionOutput[]
  qcChecks           QCCheck[]
  wasteEvents        WasteEvent[]

  @@index([tenantId])
  @@index([tenantId, inventoryItemId])
  @@index([tenantId, expiryAt])
}

model InventoryBalance {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  locationId      String        @db.Uuid
  inventoryItemId String        @db.Uuid
  lotId           String?       @db.Uuid
  onHandQty       Decimal       @default(0) @db.Decimal(14, 4)
  reservedQty     Decimal       @default(0) @db.Decimal(14, 4)
  availableQty    Decimal       @default(0) @db.Decimal(14, 4)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
