  lot               InventoryLot?   @relation(fields: [lotId], references: [id], onDelete: SetNull)
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, productionBatchId])
}

model WasteEvent {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  locationId        String           @db.Uuid
  inventoryItemId   String           @db.Uuid
  lotId             String?          @db.Uuid
  productionBatchId String?          @db.Uuid
  quantity          Decimal          @db.Decimal(14, 4)
  uom               String
  reasonCode        WasteReasonCode
  notes             String?
  costImpact        Decimal          @db.Decimal(14, 4)
  recordedById      String?          @db.Uuid
  voidedAt          DateTime?
  voidedById        String?          @db.Uuid
  voidReason        String?
  createdAt         DateTime         @default(now())
  inventoryItem     InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  location          Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot               InventoryLot?    @relation(fields: [lotId], references: [id], onDelete: SetNull)
  productionBatch   ProductionBatch? @relation(fields: [productionBatchId], references: [id], onDelete: SetNull)
  recordedBy        User?            @relation("WasteRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  voidedBy          User?            @relation("WasteVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([tenantId, reasonCode])
  @@index([tenantId, voidedAt])
}

model QCCheck {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  locationId        String           @db.Uuid
  productionBatchId String?          @db.Uuid
  inventoryLotId    String?          @db.Uuid
  status            QCStatus         @default(PENDING)
  score             Decimal?         @db.Decimal(6, 2)
  notes             String?
  imageUrl          String?
  checkedById       String?          @db.Uuid
  createdAt         DateTime         @default(now())
  checkedBy         User?            @relation("QCCheckedBy", fields: [checkedById], references: [id], onDelete: SetNull)
  inventoryLot      InventoryLot?    @relation(fields: [inventoryLotId], references: [id], onDelete: SetNull)
  location          Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  productionBatch   ProductionBatch? @relation(fields: [productionBatchId], references: [id], onDelete: SetNull)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([tenantId, status])
}

model DailyClose {
  id           String           @id @default(uuid()) @db.Uuid
  tenantId     String           @db.Uuid
  locationId   String           @db.Uuid
  businessDate DateTime
  status       DailyCloseStatus @default(DRAFT)
  salesTotal   Decimal          @db.Decimal(14, 4)
  cogsTotal    Decimal          @db.Decimal(14, 4)
  wasteTotal   Decimal          @db.Decimal(14, 4)
  grossProfit  Decimal          @db.Decimal(14, 4)
  labourCost   Decimal          @db.Decimal(14, 4)
  netEstimate  Decimal          @db.Decimal(14, 4)
  closedById   String?          @db.Uuid
  closedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  closedBy     User?            @relation("DailyCloseClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  location     Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId, businessDate])
  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([tenantId, status])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  actorId       String?  @db.Uuid
  action        String
  entityType    String
  entityId      String?
  beforeJson    Json?
  afterJson     Json?
  correlationId String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([correlationId])
}

model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  key          String
  route        String
  method       String
  requestHash  String
  responseHash String?
  statusCode   Int?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, route, method])
  @@index([tenantId])
  @@index([tenantId, expiresAt])
}

model WebhookInbox {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  provider     String
  eventId      String
  eventType    String
  payloadJson  Json
  payloadHash  String
  status       WebhookStatus @default(RECEIVED)
  receivedAt   DateTime      @default(now())
  processedAt  DateTime?
  errorMessage String?
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, eventId])
  @@index([tenantId])
  @@index([tenantId, status])
}
