  @@unique([tenantId, locationId, businessDate, productVariantId], map: "SalesEntry_loc_date_variant_key")
  @@index([tenantId])
  @@index([tenantId, locationId, businessDate])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  actorId       String?  @db.Uuid
  action        String
  entityType    String
  entityId      String?
  beforeJson    Json?
  afterJson     Json?
  correlationId String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([correlationId])
}

model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  key          String
  route        String
  method       String
  requestHash  String
  responseHash String?
  statusCode   Int?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, route, method])
  @@index([tenantId])
  @@index([tenantId, expiresAt])
}

model WebhookInbox {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  provider     String
  eventId      String
  eventType    String
  payloadJson  Json
  payloadHash  String
  status       WebhookStatus @default(RECEIVED)
  receivedAt   DateTime      @default(now())
  processedAt  DateTime?
  errorMessage String?
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, eventId])
  @@index([tenantId])
  @@index([tenantId, status])
}
