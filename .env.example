NODE_ENV=production
PORT=3010
HOST=0.0.0.0
# Preferred explicit database URL for Prisma / NestJS.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Railway fallback variables if you do not set DATABASE_URL directly.
# DATABASE_PRIVATE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# DATABASE_PUBLIC_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# POSTGRES_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# PGHOST=your-railway-postgres-host
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=replace-with-db-password
# PGDATABASE=bakestack_backend
# PGSSLMODE=require
CORS_ORIGINS=https://bakestack.netlify.app
DEFAULT_TENANT_HEADER=x-tenant-id
DEFAULT_LOCATION_HEADER=x-location-id
# Optional legacy security bridge. Keep only while unmigrated legacy auth endpoints are in use.
# SECURITY_BASE_URL=https://your-security-service.up.railway.app
# SECURITY_INTERNAL_SERVICE_API_KEY=replace-with-shared-internal-service-api-key
SECURITY_INTERNAL_SERVICE_NAME=bakestake-backend
SECURITY_SESSION_COOKIE_NAME=bk_session
# Temporary Appwrite bridge for JWT-authenticated CRM requests during migration.
APPWRITE_ENDPOINT=https://<region>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=replace-with-appwrite-project-id
APPWRITE_DATABASE_ID=bakestack
# Server-only key for Appwrite Messaging/Users and PostgreSQL -> Appwrite TablesDB mirroring.
# Do not expose this to the CRM UI.
APPWRITE_API_KEY=replace-with-appwrite-server-api-key
# Optional provider IDs. If omitted, BakeStack will use the first enabled provider of the matching type.
APPWRITE_EMAIL_PROVIDER_ID=
APPWRITE_SMS_PROVIDER_ID=
APPWRITE_PUSH_PROVIDER_ID=
SUPPLIER_MESSAGING_DEFAULT_CHANNEL=EMAIL
SUPPLIER_MESSAGING_FROM_NAME=BakeStack
SUPPLIER_MESSAGING_REPLY_TO_EMAIL=procurement@example.com
SUPPLIER_PORTAL_BASE_URL=http://localhost:5173/supplier
# Optional internal Appwrite topic for non-confidential staff alerts.
APPWRITE_INTERNAL_PROCUREMENT_TOPIC_ID=
APPWRITE_INTERNAL_PROCUREMENT_TOPIC_PREFIX=procurement-manager-
