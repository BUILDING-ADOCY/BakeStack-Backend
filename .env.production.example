NODE_ENV=production
PORT=3010
HOST=0.0.0.0

# Primary Prisma / NestJS database connection.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# Exact frontend origin allowed to call this backend from the browser.
CORS_ORIGINS=https://bakestack.netlify.app

# This backend proxies auth/session work to the security service.
SECURITY_BASE_URL=https://<your-security-service>.up.railway.app
SECURITY_INTERNAL_SERVICE_API_KEY=replace_with_shared_internal_service_api_key
SECURITY_INTERNAL_SERVICE_NAME=bakestake-backend
SECURITY_SESSION_COOKIE_NAME=bk_session

# Optional request context defaults. Leave empty in production unless you intentionally use them.
DEFAULT_TENANT_HEADER=
DEFAULT_LOCATION_HEADER=
